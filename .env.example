# GitHub OAuth App (https://github.com/settings/developers)
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# Optional: personal access token (no special scopes needed) used by the
# continuous background discovery worker. Without it, discovery still runs
# forever in the background, just at the slower unauthenticated pace
# (10 req/min vs 5000 points/hour via GraphQL with a token).
GITHUB_TOKEN=

# Generate with: npx auth secret  (or `openssl rand -base64 32`)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
